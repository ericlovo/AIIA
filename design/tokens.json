{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "name": "aiia-tokens",
  "version": "0.1.0",
  "source": "Extracted from ericlovo/aiia-console (Tailwind 4.3) on 2026-05-12. aiia-console is the canonical implementation; this document mirrors what is actually used in the desktop app.",
  "mode": "dark-first",
  "color": {
    "surface": {
      "deepest":  "neutral-950",
      "base":     "neutral-900",
      "raised":   "neutral-800",
      "control":  "neutral-700",
      "hover":    "neutral-600"
    },
    "text": {
      "primary":   "neutral-100",
      "secondary": "neutral-300",
      "muted":     "neutral-400",
      "subtle":    "neutral-500",
      "disabled":  "neutral-600"
    },
    "border": {
      "subtle":    "neutral-800",
      "default":   "neutral-700",
      "strong":    "neutral-600",
      "interactive": "neutral-500"
    },
    "accent": {
      "primary":  "emerald-500",
      "primaryHover": "emerald-400",
      "primaryDeep":  "emerald-900",
      "focusRing":    "emerald-500"
    },
    "status": {
      "success": "emerald-500",
      "warning": "amber-500",
      "danger":  "rose-500",
      "info":    "indigo-500"
    },
    "statusSurface": {
      "successSurface": "emerald-950",
      "warningSurface": "amber-950",
      "dangerSurface":  "rose-950",
      "infoSurface":    "indigo-950"
    }
  },
  "typography": {
    "note": "aiia-console uses the system font stack via Tailwind defaults. No custom font is loaded as of v0.1."
  },
  "radius": {
    "note": "Tailwind defaults in use (sm/md/lg/xl/2xl). No custom radii defined."
  },
  "spacing": {
    "note": "Tailwind defaults in use. No custom scale."
  }
}
